{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "disabled": true,
      "autoApprove": []
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<PERSONAL_TOKEN>"
      },
      "disabled": true,
      "autoApprove": []
    },
    "fetch": {
      "command": "uvx.exe",
      "args": ["mcp-server-fetch"],
      "disabled": true,
      "autoApprove": []
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "disabled": true,
      "autoApprove": []
    }
  }
}
