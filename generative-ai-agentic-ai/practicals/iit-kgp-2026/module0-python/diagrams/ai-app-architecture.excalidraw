    {
      "id": "side-note",
      "type": "text",
      "x": 700,
      "y": 160,
      "width": 150,
      "height": 180,
      "text": "📋 HOW IT WORKS:\n\n1. User asks question\n   in Streamlit chat\n\n2. FastAPI validates\n   request (Pydantic)\n\n3. LangChain retrieves\n   from ChromaDB\n\n4. HuggingFace model\n   generates answer\n\n5. NumPy/Pandas did\n   the data prep",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 70,
      "version": 3,
      "groupIds": [],
      "boundElements": [],
      "link": null,
      "locked": false,
      "versionNonce": 1443337121,
      "index": "aoV",
      "isDeleted": false,
      "strokeStyle": "solid",
      "frameId": null,
      "roundness": null,
      "updated": 1781778507692,
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "📋 HOW IT WORKS:\n\n1. User asks question\n   in Streamlit chat\n\n2. FastAPI validates\n   request (Pydantic)\n\n3. LangChain retrieves\n   from ChromaDB\n\n4. HuggingFace model\n   generates answer\n\n5. NumPy/Pandas did\n   the data prep",
      "autoResize": true,
      "lineHeight": 1.0227272727272727
    },
